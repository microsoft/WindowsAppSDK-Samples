<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <!--
      When IncludeExperimentalApis is true (default), the sample is built against the experimental
      Windows App SDK package and includes the experimental-only features under */Experimental/.
      Pass /p:IncludeExperimentalApis=false on the command line (or set it in the .csproj) to
      build against the latest stable Windows App SDK; the experimental folders are then excluded
      from the build and their navigation entries are removed at runtime.
    -->
    <IncludeExperimentalApis Condition="'$(IncludeExperimentalApis)'==''">true</IncludeExperimentalApis>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core -->
    <PackageVersion Condition="'$(IncludeExperimentalApis)'=='true'" Include="Microsoft.WindowsAppSDK" Version="2.1.4-experimental8" />
    <PackageVersion Condition="'$(IncludeExperimentalApis)'!='true'" Include="Microsoft.WindowsAppSDK" Version="2.1.3" />
  </ItemGroup>
</Project>