<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Per-feature extensibility model:
      Stable + experimental features live as independent class libraries under
      Extensions/<FeatureName>/. The list (and per-feature maturity) is
      declared in Extensions.props. The main exe ProjectReferences Contracts and
      whichever extensions match the current build flavor, then discovers
      [NavPage]-decorated Page types at startup via reflection.

      See Extensions.props for how to add or promote a feature.
  -->
  <Import Project="Extensions.props" />

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.22621.0</TargetPlatformMinVersion>
    <RootNamespace>WindowsAISample</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
    <UseWinUI>true</UseWinUI>
    <EnableMsixTooling>true</EnableMsixTooling>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAppInstallerFile>False</GenerateAppInstallerFile>
    <AppxPackageSigningEnabled>True</AppxPackageSigningEnabled>
    <AppxPackageSigningTimestampDigestAlgorithm>SHA256</AppxPackageSigningTimestampDigestAlgorithm>
    <AppxAutoIncrementPackageRevision>False</AppxAutoIncrementPackageRevision>
    <AppxSymbolPackageEnabled>False</AppxSymbolPackageEnabled>
    <GenerateTestArtifacts>True</GenerateTestArtifacts>
    <AppxBundle>Never</AppxBundle>
    <HoursBetweenUpdateChecks>0</HoursBetweenUpdateChecks>
    <AppxOSMinVersionReplaceManifestVersion>false</AppxOSMinVersionReplaceManifestVersion>
    <AppxOSMaxVersionTestedReplaceManifestVersion>false</AppxOSMaxVersionTestedReplaceManifestVersion>

    <IncludeExperimentalApis Condition="'$(IncludeExperimentalApis)'==''">true</IncludeExperimentalApis>
  </PropertyGroup>

  <!--
    Exclude Contracts/ and Extensions/ subtrees from the main project's
    implicit Compile/Page globs: those folders belong to sibling class library
    projects referenced via ProjectReference. Without these removes the main
    exe would double-compile their source and trigger CS0436 type-conflict
    warnings.
  -->
  <ItemGroup>
    <Compile Remove="Contracts\**\*.cs" />
    <Page Remove="Contracts\**\*.xaml" />
    <None Remove="Contracts\**" />
    <Compile Remove="Extensions\**\*.cs" />
    <Page Remove="Extensions\**\*.xaml" />
    <None Remove="Extensions\**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="Contracts\WindowsAISample.Contracts.csproj" />
  </ItemGroup>

  <!-- Stable extensions: always referenced. -->
  <ItemGroup>
    <ProjectReference Include="@(StableExtension -> 'Extensions\%(Identity)\WindowsAISample.Ext.%(Identity).csproj')" />
  </ItemGroup>

  <!-- Experimental extensions: referenced only when IncludeExperimentalApis=true. -->
  <ItemGroup Condition="'$(IncludeExperimentalApis)'=='true'">
    <ProjectReference Include="@(ExperimentalExtension -> 'Extensions\%(Identity)\WindowsAISample.Ext.%(Identity).csproj')" />
  </ItemGroup>

  <!-- Stable and experimental build artifacts are isolated per flavor in Directory.Build.props,
       so switching IncludeExperimentalApis does not require a 'dotnet clean' in between. -->

  <ItemGroup>
    <None Remove="Examples\ImageObjectExtractor.md" />
    <None Remove="Examples\ImageObjectExtractorInit.md" />
    <None Remove="Examples\ImageScaler.md" />
    <None Remove="Examples\LanguageModelWithContext.md" />
    <None Remove="Examples\LanguageModelWithOptionsAndProgress.md" />
    <None Remove="Examples\LanguageModelWithProgress.md" />
    <None Remove="Examples\TextRecognizer.md" />
    <None Remove="Examples\TextRecognizerInit.md" />
    <None Remove="Pages\ImageDescriptionPage.xaml" />
    <None Remove="Pages\ImageObjectExtractorPage.xaml" />
    <None Remove="Pages\ImageScalerPage.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\*.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Assets\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Examples\*.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" />
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>

  <ItemGroup Condition="'$(DisableMsixProjectCapabilityAddedByProject)'!='true' and '$(EnablePreviewMsixTooling)'=='true'">
    <ProjectCapability Include="Msix" />
  </ItemGroup>
  <ItemGroup>
    <Content Update="Assets\harbor.jpg">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageDescriptionPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageObjectExtractorPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageScalerPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\LanguageModelPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\TextRecognizerPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
</Project>
