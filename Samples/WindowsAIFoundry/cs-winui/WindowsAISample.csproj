<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Per-feature extensibility model:
      Stable + experimental features live as independent class libraries under
      Extensions/<FeatureName>/. The list (and per-feature maturity) is
      declared in Extensions.props. The main exe ProjectReferences Shared and
      whichever extensions match the current build flavor, then discovers
      [NavPage]-decorated Page types at startup via reflection.

      See Extensions.props for how to add or promote a feature.
  -->
  <Import Project="Extensions.props" />

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.22621.0</TargetPlatformMinVersion>
    <RootNamespace>WindowsAISample</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
    <UseWinUI>true</UseWinUI>
    <EnableMsixTooling>true</EnableMsixTooling>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAppInstallerFile>False</GenerateAppInstallerFile>
    <AppxPackageSigningEnabled>True</AppxPackageSigningEnabled>
    <AppxPackageSigningTimestampDigestAlgorithm>SHA256</AppxPackageSigningTimestampDigestAlgorithm>
    <AppxAutoIncrementPackageRevision>False</AppxAutoIncrementPackageRevision>
    <AppxSymbolPackageEnabled>False</AppxSymbolPackageEnabled>
    <GenerateTestArtifacts>True</GenerateTestArtifacts>
    <AppxBundle>Never</AppxBundle>
    <HoursBetweenUpdateChecks>0</HoursBetweenUpdateChecks>
    <AppxOSMinVersionReplaceManifestVersion>false</AppxOSMinVersionReplaceManifestVersion>
    <AppxOSMaxVersionTestedReplaceManifestVersion>false</AppxOSMaxVersionTestedReplaceManifestVersion>

    <IncludeExperimentalApis Condition="'$(IncludeExperimentalApis)'==''">true</IncludeExperimentalApis>
  </PropertyGroup>

  <!--
    Exclude Shared/ and Extensions/ subtrees from the main project's implicit
    Compile/Page globs: those folders belong to sibling class library projects
    referenced via ProjectReference. Without these removes the main exe would
    double-compile their source and trigger CS0436 type-conflict warnings.
  -->
  <ItemGroup>
    <Compile Remove="Shared\**\*.cs" />
    <Page Remove="Shared\**\*.xaml" />
    <None Remove="Shared\**" />
    <Compile Remove="Extensions\**\*.cs" />
    <Page Remove="Extensions\**\*.xaml" />
    <None Remove="Extensions\**" />
  </ItemGroup>

  <!-- Shared infrastructure consumed by both main and extensions. -->
  <ItemGroup>
    <ProjectReference Include="Shared\WindowsAISample.Shared.csproj" />
  </ItemGroup>

  <!-- Stable extensions: always referenced. -->
  <ItemGroup>
    <ProjectReference Include="@(StableExtension -> 'Extensions\%(Identity)\WindowsAISample.Ext.%(Identity).csproj')" />
  </ItemGroup>

  <!-- Experimental extensions: referenced only when IncludeExperimentalApis=true. -->
  <ItemGroup Condition="'$(IncludeExperimentalApis)'=='true'">
    <ProjectReference Include="@(ExperimentalExtension -> 'Extensions\%(Identity)\WindowsAISample.Ext.%(Identity).csproj')" />
  </ItemGroup>

  <!--
    Emit a tiny generated source file listing exactly which extension assemblies this build expects to find at
    runtime. The MainWindow uses this list to filter the Assembly.LoadFrom wildcard, so a stale Ext.dll left in
    bin/ from a previous experimental build will NOT be loaded by a subsequent stable build.
  -->
  <Target Name="GenerateExtensionsManifest"
          BeforeTargets="BeforeCompile;CoreCompile;MarkupCompilePass1;MarkupCompilePass2">
    <ItemGroup>
      <_ExpectedExtension Include="@(StableExtension)" />
      <_ExpectedExtension Include="@(ExperimentalExtension)" Condition="'$(IncludeExperimentalApis)'=='true'" />
    </ItemGroup>
    <PropertyGroup>
      <_ExtensionAssemblyNamesCsv>@(_ExpectedExtension -> '&quot;WindowsAISample.Ext.%(Identity)&quot;', ', ')</_ExtensionAssemblyNamesCsv>
      <_GeneratedManifestPath>$(IntermediateOutputPath)GeneratedExtensionsManifest.cs</_GeneratedManifestPath>
    </PropertyGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <ItemGroup>
      <_ManifestLines Include="// &lt;auto-generated /&gt;" />
      <_ManifestLines Include="namespace WindowsAISample%3B" />
      <_ManifestLines Include="internal static class GeneratedExtensionsManifest" />
      <_ManifestLines Include="{" />
      <_ManifestLines Include="    public static readonly string[] ExpectedAssemblyNames = new string[] { $(_ExtensionAssemblyNamesCsv) }%3B" />
      <_ManifestLines Include="}" />
    </ItemGroup>
    <WriteLinesToFile File="$(_GeneratedManifestPath)"
                      Lines="@(_ManifestLines)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
    <ItemGroup>
      <Compile Include="$(_GeneratedManifestPath)" Visible="false" />
      <FileWrites Include="$(_GeneratedManifestPath)" />
    </ItemGroup>
  </Target>

  <!--
    Detects a flavor switch (experimental <-> stable) and wipes IntermediateOutputPath so cached XAML metadata
    (XamlTypeInfo.g.cs, *.g.cs, *.g.i.cs) regenerates. Without this, references to experimental-only Page types
    leak from a prior experimental obj/ into the next stable build as CS1061/CS0234. project.assets.json lives in
    BaseIntermediateOutputPath (obj/), not IntermediateOutputPath (obj/<TFM>/<RID>/), so NuGet restore is preserved.
  -->
  <Target Name="InvalidateXamlOnFlavorChange"
          BeforeTargets="GenerateExtensionsManifest;MarkupCompilePass1;PrepareForBuild">
    <PropertyGroup>
      <_FlavorMarker>$(IntermediateOutputPath)flavor.marker</_FlavorMarker>
      <_CurrentFlavor Condition="'$(IncludeExperimentalApis)'=='true'">experimental</_CurrentFlavor>
      <_CurrentFlavor Condition="'$(IncludeExperimentalApis)'!='true'">stable</_CurrentFlavor>
      <_LastFlavor>none</_LastFlavor>
      <_LastFlavor Condition="Exists('$(_FlavorMarker)')">$([System.IO.File]::ReadAllText('$(_FlavorMarker)').Trim())</_LastFlavor>
    </PropertyGroup>
    <Message Importance="high"
             Text="Flavor switch detected ($(_LastFlavor) -&gt; $(_CurrentFlavor)); wiping $(IntermediateOutputPath) so XAML metadata regenerates."
             Condition="'$(_LastFlavor)' != 'none' and '$(_LastFlavor)' != '$(_CurrentFlavor)'" />
    <RemoveDir Directories="$(IntermediateOutputPath)"
               Condition="'$(_LastFlavor)' != 'none' and '$(_LastFlavor)' != '$(_CurrentFlavor)'" />
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <WriteLinesToFile File="$(_FlavorMarker)"
                      Lines="$(_CurrentFlavor)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
  </Target>

  <ItemGroup>
    <None Remove="Examples\ImageObjectExtractor.md" />
    <None Remove="Examples\ImageObjectExtractorInit.md" />
    <None Remove="Examples\ImageScaler.md" />
    <None Remove="Examples\LanguageModelWithContext.md" />
    <None Remove="Examples\LanguageModelWithOptionsAndProgress.md" />
    <None Remove="Examples\LanguageModelWithProgress.md" />
    <None Remove="Examples\TextRecognizer.md" />
    <None Remove="Examples\TextRecognizerInit.md" />
    <None Remove="Pages\ImageDescriptionPage.xaml" />
    <None Remove="Pages\ImageObjectExtractorPage.xaml" />
    <None Remove="Pages\ImageScalerPage.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\*.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Assets\*.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Examples\*.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" />
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>

  <ItemGroup Condition="'$(DisableMsixProjectCapabilityAddedByProject)'!='true' and '$(EnablePreviewMsixTooling)'=='true'">
    <ProjectCapability Include="Msix" />
  </ItemGroup>
  <ItemGroup>
    <Content Update="Assets\harbor.jpg">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageDescriptionPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageObjectExtractorPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\ImageScalerPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\LanguageModelPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Page Update="Pages\TextRecognizerPage.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>
</Project>
