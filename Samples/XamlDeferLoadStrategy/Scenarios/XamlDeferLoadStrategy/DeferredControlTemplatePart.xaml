<Page
    x:Class="SDKTemplate.DeferredControlTemplatePart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SDKTemplate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Margin="12">
        <TextBlock Text="Deferral can be used in control templates to prevent creation of lesser used template parts. Look at the generic.xaml in the Themes folder of this project and at TitledImage.cs to see the source for this example." MaxWidth="560" Margin="0,0,12,12" HorizontalAlignment="Left" TextWrapping="WrapWholeWords" />
        <local:TitledImage Header="Logo" Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" /> <!--This one will realize the header content presenter in the control template that was deferred -->
        <local:TitledImage Source="ms-appx:///Assets/Wide310x150Logo.scale-200.png" Margin="0,12,0,0" /> <!--This one will not realize the header content presenter because Header was not specified -->
    </StackPanel>
</Page>
