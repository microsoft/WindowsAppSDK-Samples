<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="15.0">

  <!--
    We want MRT Core to NOT be used in WAP or legacy UWP projects. Instead, we want the in-box PRI generation tooling to be used.
    The 'EnableCoreMrtTooling' property is disabled from 'Microsoft.Windows.SDK.BuildTools.MSIX.Common.props', which is imported
    conditionally after the .csproj, if 'EnableMsixTooling' is set. The main scenario where it will be enabled, and where we do
    need MRT Core to generate PRI files, is when building an app that's then packaged with a separate WAP project. In that case,
    we need MRT Core to produce the XBF and PRI files that the WAP project will consume and put in the final MSIX. When using
    a separate WAP project, 'EnableMsixTooling' will not be set in the app, as that's only for single-project MSIX support.
  -->
  <PropertyGroup>
    <EnableCoreMrtTooling Condition="'$(EnableCoreMrtTooling)'=='' and '$(WindowsAppContainer)'!='true' and '$(MSBuildProjectExtension)' != '.wapproj'">true</EnableCoreMrtTooling>
  </PropertyGroup>

  <!--
    Import required tasks when either MRT Core is enabled, or when PRI resource expansion is.
  -->
  <Import Project="Microsoft.Windows.SDK.BuildTools.MSIX.MrtCore.Tasks.targets" Condition="'$(EnableCoreMrtTooling)' == 'true' or '$(ExpandPriResources)' != 'false'" />

  <Import Project="$(MSBuildThisFileDirectory)Microsoft.Windows.SDK.BuildTools.MSIX.MrtCore.PriGen.targets" Condition="'$(EnableCoreMrtTooling)' == 'true'" />

  <!--
    Even if MRT Core is not enabled, we still want to expand PRI resources, unless explicitly disabled.
    This is required so that assets flowing from NuGet packages are correctly copied to the output directory.
  -->
  <Import Project="$(MSBuildThisFileDirectory)Microsoft.Windows.SDK.BuildTools.MSIX.MrtCore.PriExpansion.targets" Condition="'$(EnableCoreMrtTooling)' != 'true' and '$(ExpandPriResources)' != 'false'"/>

</Project>
