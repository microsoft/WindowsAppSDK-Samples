<Page
    x:Class="SDKTemplate.Scenario1_ListDetails"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SDKTemplate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Margin="12,20,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="Description:" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap">
                The list/details pattern shows a list of items next to the details of the selected item.
                When the window is wide the list and details appear side by side; when it is narrow the
                view collapses to a single pane and tapping an item drills in to its details. Resize the
                window past 720&#160;pixels to see the layout adapt.
            </TextBlock>
        </StackPanel>

        <Grid x:Name="LayoutRoot" Grid.Row="1" SizeChanged="LayoutRoot_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MasterColumn" Width="320"/>
                <ColumnDefinition x:Name="DetailColumn" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Master (list) pane -->
            <Grid x:Name="MasterPane" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="My Items" Margin="4,4,8,8" Style="{StaticResource SubtitleTextBlockStyle}"/>

                <ListView
                    x:Name="MasterListView"
                    Grid.Row="1"
                    IsItemClickEnabled="True"
                    ItemClick="MasterListView_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ItemViewModel">
                            <Grid Margin="0,11,0,13">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource BaseTextBlockStyle}"/>
                                <TextBlock
                                    Text="{x:Bind Text}"
                                    Grid.Row="1"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock
                                    Text="{x:Bind DateCreatedHourMinute}"
                                    Grid.Column="1"
                                    Margin="12,1,0,0"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Detail pane -->
            <Grid
                x:Name="DetailPane"
                Grid.Column="1"
                Padding="24,0"
                BorderThickness="1,0,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button
                    x:Name="BackButton"
                    Margin="0,4,0,0"
                    Visibility="Collapsed"
                    Click="BackButton_Click"
                    AutomationProperties.Name="Back to list">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72B;" FontSize="16"/>
                </Button>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            x:Name="NoSelectionText"
                            Text="Select an item to see its details."
                            Margin="0,8"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                            <TextBlock x:Name="DetailTitle" Margin="0,8" Style="{StaticResource TitleTextBlockStyle}"/>
                            <TextBlock x:Name="DetailDate" Margin="0,0,0,8" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="DetailText" MaxWidth="560" HorizontalAlignment="Left" Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
