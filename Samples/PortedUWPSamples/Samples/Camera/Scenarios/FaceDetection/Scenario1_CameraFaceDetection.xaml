<Page
    x:Class="SDKTemplate.Scenario1_CameraFaceDetection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SDKTemplate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="TranslucentBlackBrush" Color="Black" Opacity="0.3" />
    </Page.Resources>

    <Grid SizeChanged="PageRoot_SizeChanged">
        <MediaPlayerElement
            x:Name="PreviewControl"
            AreTransportControlsEnabled="False"
            Stretch="Uniform" />

        <Border
            x:Name="PreviewPlaceholder"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="520"
            Padding="24"
            Background="{StaticResource TranslucentBlackBrush}"
            CornerRadius="8">
            <TextBlock
                x:Name="PreviewMessage"
                Foreground="White"
                Text="Camera preview is not available."
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </Border>

        <Canvas IsHitTestVisible="False">
            <Canvas
                x:Name="FacesCanvas"
                RenderTransformOrigin="0.5,0.5"
                Visibility="Collapsed" />
        </Canvas>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="20">
            <StackPanel.Resources>
                <Style TargetType="Viewbox">
                    <Setter Property="MaxHeight" Value="40" />
                    <Setter Property="MaxWidth" Value="40" />
                </Style>
            </StackPanel.Resources>

            <Button
                x:Name="PhotoButton"
                Margin="10"
                MinWidth="80"
                MinHeight="80"
                RenderTransformOrigin="0.5,0.5"
                Click="PhotoButton_Click"
                IsEnabled="False">
                <Viewbox>
                    <SymbolIcon Symbol="Camera" />
                </Viewbox>
            </Button>

            <Button
                x:Name="VideoButton"
                Margin="10"
                MinWidth="80"
                MinHeight="80"
                RenderTransformOrigin="0.5,0.5"
                Click="VideoButton_Click"
                IsEnabled="False">
                <Grid>
                    <Ellipse
                        x:Name="StartRecordingIcon"
                        Width="20"
                        Height="20"
                        Fill="Red" />
                    <Rectangle
                        x:Name="StopRecordingIcon"
                        Width="20"
                        Height="20"
                        Fill="White"
                        Visibility="Collapsed" />
                </Grid>
            </Button>
        </StackPanel>

        <Button
            x:Name="FaceDetectionButton"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10,40"
            MinWidth="80"
            MinHeight="80"
            Click="FaceDetectionButton_Click"
            IsEnabled="False">
            <Viewbox MaxHeight="40" MaxWidth="40">
                <Grid>
                    <SymbolIcon
                        x:Name="FaceDetectionDisabledIcon"
                        Symbol="Contact"
                        Visibility="Visible" />
                    <SymbolIcon
                        x:Name="FaceDetectionEnabledIcon"
                        Symbol="Contact2"
                        Visibility="Collapsed" />
                </Grid>
            </Viewbox>
        </Button>
    </Grid>
</Page>
