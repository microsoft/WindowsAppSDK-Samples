<Page x:Class="SDKTemplate.Scenario1_Files"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <ScrollViewer VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="8">
            <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                Files are ideal for storing large data sets, databases, or data that is in a common file format. This scenario writes counters to the Local, LocalCache, and Temporary app data folders.
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="IncrementLocal" Content="Increment Local" Click="Increment_Local_Click"/>
                <TextBlock x:Name="LocalOutputTextBlock" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="IncrementLocalCache" Content="Increment LocalCache" Click="Increment_LocalCache_Click"/>
                <TextBlock x:Name="LocalCacheOutputTextBlock" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="IncrementTemporary" Content="Increment Temporary" Click="Increment_Temporary_Click"/>
                <TextBlock x:Name="TemporaryOutputTextBlock" VerticalAlignment="Center" Style="{StaticResource BodyTextBlockStyle}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
