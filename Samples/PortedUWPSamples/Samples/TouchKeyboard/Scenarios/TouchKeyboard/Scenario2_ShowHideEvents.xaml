<Page
    x:Class="SDKTemplate.Scenario2_ShowHideEvents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SDKTemplate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="16,24,16,16">
        <StackPanel Spacing="8">
            <TextBlock Text="Description" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock TextWrapping="Wrap">
                The Showing and Hiding events are raised when the touch keyboard is shown or hidden.
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Margin="0,12,0,0">
                Last event: <Run x:Name="LastInputPaneEventRun" />
            </TextBlock>

            <TextBox
                AutomationProperties.AutomationId="EventTextBox"
                PlaceholderText="Tap to show the touch keyboard"
                Margin="0,12,0,0" />
            <TextBlock
                TextWrapping="Wrap"
                Text="The touch keyboard hides when focus is not in a text control."
                Margin="0,12,0,0" />
            <Button
                AutomationProperties.AutomationId="EventDismissButton"
                Content="Dismiss keyboard"
                Margin="0,12,0,0" />

            <TextBlock TextWrapping="Wrap" Margin="0,12,0,0">
                See the note in scenario 1 for the rules regarding the touch keyboard.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>
