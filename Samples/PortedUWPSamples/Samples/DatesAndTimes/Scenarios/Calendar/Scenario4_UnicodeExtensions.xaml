<Page
    x:Class="SDKTemplate.Scenario4_UnicodeExtensions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid x:Name="RootGrid" Margin="12,20,12,12">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Description:" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap" Margin="0,10,0,0">
                        Creates a calendar using language names with supported Unicode extension tags and
                        demonstrates how the extension tags are used by the calendar object.
                    </TextBlock>
                    <Button Content="Show results" Margin="0,10,0,0" Click="ShowResults_Click"/>
                    <TextBlock x:Name="OutputTextBlock" Margin="0,10,0,0" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
