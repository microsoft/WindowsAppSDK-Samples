<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Ported subset of the UWP SDKTemplate Styles.xaml. The scenario pages reference
        BasicTextStyle for body copy; it is rebased onto the WinUI 3 built-in
        BodyTextBlockStyle. The rest of the original shell styles are no longer needed
        because the shell now uses a NavigationView + InfoBar instead of the UWP
        SplitView/ListBox template.
    -->

    <Style x:Key="BasicTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- UWP SDKTemplate scenario styles, rebased onto WinUI 3 built-ins so scenario pages
         port with minimal edits. -->
    <Style x:Key="ScenarioDescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BaseMessageStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
