<Window x:Class="PrimaryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Primary Sparse App - Multi-Headed Sparse Package" Height="400" Width="600">

    <StackPanel Margin="20">
        <TextBlock Text="Multi-Headed Sparse Package Sample"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />
        <TextBlock Text="This is the Primary App in a multi-headed sparse package."
                   FontSize="14" Margin="0,0,0,20" />

        <TextBlock Text="Package Identity Status:" FontWeight="Bold" Margin="0,0,0,5" />
        <TextBlock x:Name="StatusText" Text="Checking..." Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="RegisterButton" Content="Register Package"
                    Click="RegisterButton_Click" Margin="0,0,10,0" Padding="10,5" />
            <Button x:Name="UnregisterButton" Content="Unregister Package"
                    Click="UnregisterButton_Click" Margin="0,0,10,0" Padding="10,5" />
            <Button x:Name="RestartButton" Content="Restart"
                    Click="RestartButton_Click" Margin="0,0,10,0" Padding="10,5" />
            <Button x:Name="LaunchSecondaryButton" Content="Launch Secondary App"
                    Click="LaunchSecondaryButton_Click" Padding="10,5" />
        </StackPanel>

        <TextBlock Text="Output:" FontWeight="Bold" Margin="0,10,0,5" />
        <TextBox x:Name="OutputTextBox" IsReadOnly="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Height="150"
                 Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
    </StackPanel>
</Window>
