<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TouchKeyboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TouchKeyboard"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TouchKeyboard"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Touch Keyboard Sample">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    AutomationProperties.AutomationId="Scenario1NavItem"
                    Content="Display touch keyboard automatically"
                    Tag="Scenario1" />
                <NavigationViewItem
                    AutomationProperties.AutomationId="Scenario2NavItem"
                    Content="Listen for Show/Hide events"
                    Tag="Scenario2" />
                <NavigationViewItem
                    AutomationProperties.AutomationId="Scenario3NavItem"
                    Content="Programmatically Show/Hide"
                    Tag="Scenario3" />
                <NavigationViewItem
                    AutomationProperties.AutomationId="Scenario4NavItem"
                    Content="Showing the Emoji keyboard"
                    Tag="Scenario4" />
            </NavigationView.MenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Frame x:Name="ContentFrame" Grid.Row="0" />

                <InfoBar
                    x:Name="StatusInfoBar"
                    Grid.Row="1"
                    IsOpen="False"
                    AutomationProperties.AutomationId="StatusInfoBar" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
