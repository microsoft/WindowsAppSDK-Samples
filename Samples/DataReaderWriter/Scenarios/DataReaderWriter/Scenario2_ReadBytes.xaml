<Page
    x:Class="SDKTemplate.ReadBytes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer x:Name="HexDumpScrollViewer" IsTabStop="False" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="LayoutRoot" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid x:Name="Input" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="Description" Grid.Row="0" HorizontalAlignment="Left" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                    This scenario opens a sequential-access stream over the image below,
                    and uses ReadBytes() to retrieve its contents in order to display a hex
                    dump its binary data.
                </TextBlock>
                <StackPanel Grid.Row="1" Margin="0,10,0,0" Orientation="Vertical">
                    <Image Source="/Assets/Square150x150Logo.scale-200.png" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" />
                    <Button x:Name="HexDumpButton" Content="Hex Dump" Margin="0,10,0,0" Click="HexDump" />
                </StackPanel>
            </Grid>
            <Grid x:Name="Output" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock x:Name="ReadBytesOutput" Grid.Row="0" HorizontalAlignment="Left" FontFamily="Courier New" FontSize="15" TextWrapping="Wrap" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
