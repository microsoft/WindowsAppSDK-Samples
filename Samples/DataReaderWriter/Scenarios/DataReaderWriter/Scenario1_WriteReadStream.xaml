<Page
    x:Class="SDKTemplate.WriteReadStream"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid x:Name="LayoutRoot" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid x:Name="Input" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <TextBlock x:Name="Description" HorizontalAlignment="Left" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        The sample code creates a memory-backed stream and then uses it to
                        store the following strings via a DataWriter object. Once this
                        operation completes a DataReader object is used to extract the stored
                        strings from the stream and display them.
                    </TextBlock>
                    <TextBlock x:Name="ElementsToWrite" HorizontalAlignment="Left" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">Hello;World;1 2 3 4 5;Tr&#xE8;s bien!;Goodbye</TextBlock>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <Button x:Name="SendButton" Content="Copy Strings" Click="TransferData" />
                </StackPanel>
            </Grid>
            <Grid x:Name="Output" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock x:Name="ElementsRead" Grid.Row="0" HorizontalAlignment="Left" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
