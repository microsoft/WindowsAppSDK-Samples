<Page
    x:Class="SDKTemplate.Scenario1_CameraAdvancedCapture"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SDKTemplate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="TranslucentBlackBrush" Color="Black" Opacity="0.3" />
    </Page.Resources>

    <Grid>
        <MediaPlayerElement
            x:Name="PreviewControl"
            AreTransportControlsEnabled="False"
            Stretch="Uniform" />

        <Border
            x:Name="PreviewPlaceholder"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="24"
            Background="{StaticResource TranslucentBlackBrush}"
            CornerRadius="8">
            <TextBlock
                x:Name="PreviewMessage"
                Foreground="White"
                Text="Camera preview is not available."
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </Border>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="20">
            <Button
                x:Name="CycleModeButton"
                Margin="10"
                MinWidth="80"
                MinHeight="80"
                RenderTransformOrigin="0.5,0.5"
                Click="CycleModeButton_Click"
                IsEnabled="False">
                <Viewbox MaxHeight="60" MaxWidth="60">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <SymbolIcon Grid.Row="0" Symbol="AttachCamera" />
                        <TextBlock
                            x:Name="ModeTextBlock"
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            FontSize="8"
                            Text="Standard" />
                    </Grid>
                </Viewbox>
            </Button>

            <Button
                x:Name="PhotoButton"
                Margin="10"
                MinWidth="80"
                MinHeight="80"
                RenderTransformOrigin="0.5,0.5"
                Click="PhotoButton_Click"
                IsEnabled="False">
                <Viewbox MaxHeight="40" MaxWidth="40">
                    <SymbolIcon Symbol="Camera" />
                </Viewbox>
            </Button>
        </StackPanel>

        <Grid VerticalAlignment="Bottom" Background="{StaticResource TranslucentBlackBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock
                Margin="10"
                Foreground="White"
                Text="HDR Analyzer:" />
            <ProgressBar
                x:Name="HdrImpactBar"
                Grid.Column="1"
                Margin="10"
                MinHeight="20"
                Opacity="0.75" />
            <TextBlock
                x:Name="SceneTypeTextBlock"
                Grid.Column="2"
                Margin="10"
                Foreground="White" />
        </Grid>
    </Grid>
</Page>
