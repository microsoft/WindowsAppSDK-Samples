<Page
    x:Class="SDKTemplate.Scenario1_DisplayDepthColorIR"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="12,20,12,12">
        <StackPanel>
            <TextBlock Text="Description:" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">
                Display multiple frame sources to screen simultaneously in shared mode access.
            </TextBlock>

            <Button x:Name="NextButton" Content="Next Source Group" Click="NextButton_Click" Margin="0,10,0,0"/>

            <Grid HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border x:Name="ColorPreviewBlock" BorderThickness="1" BorderBrush="LightGray" Grid.Column="0">
                    <StackPanel>
                        <TextBlock Text="Color frame source" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <Image x:Name="colorPreviewImage"/>
                    </StackPanel>
                </Border>
                <Border x:Name="DepthPreviewBlock" BorderThickness="1" BorderBrush="LightGray" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Depth frame source" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <Image x:Name="depthPreviewImage"/>
                    </StackPanel>
                </Border>
                <Border x:Name="InfraredPreviewBlock" BorderThickness="1" BorderBrush="LightGray" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="Infrared frame source" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <Image x:Name="infraredPreviewImage"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock x:Name="outputTextBlock" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
