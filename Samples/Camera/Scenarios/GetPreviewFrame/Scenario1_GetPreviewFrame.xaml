<Page
    x:Class="SDKTemplate.Scenario1_GetPreviewFrame"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SDKTemplate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <MediaPlayerElement
                        x:Name="PreviewControl"
                        AreTransportControlsEnabled="False"
                        Stretch="Uniform" />
                    <TextBlock
                        x:Name="PreviewPlaceholderTextBlock"
                        Margin="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="Camera preview appears here when a camera is available."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <Image x:Name="PreviewFrameImage" Stretch="Uniform" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="GetPreviewFrameButton"
                    Click="GetPreviewFrameButton_Click"
                    Content="GetPreviewFrameAsync"
                    IsEnabled="False" />
                <TextBlock
                    x:Name="FrameInfoTextBlock"
                    VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <CheckBox x:Name="ShowFrameCheckBox" Content="Show frame" />
                <CheckBox x:Name="GreenEffectCheckBox" Content="Green effect" />
                <CheckBox x:Name="SaveFrameCheckBox" Content="Save frame" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
